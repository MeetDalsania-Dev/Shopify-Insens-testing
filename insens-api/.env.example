# ─── App ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/insens_db

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cache (Valkey / Redis-compatible) ────────────────
CACHE_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGINS=https://admin.insens.com,https://seller.insens.com

# ─── App URL ──────────────────────────────────────────
APP_URL=https://api.insens.com
