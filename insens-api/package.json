{
  "name": "insens-api",
  "version": "1.0.0",
  "description": "Insens perfume marketplace backend API",
  "private": true,
  "scripts": {
    "start:dev": "bun --watch src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "drizzle-kit": "drizzle-kit",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun drizzle/migrate.ts",
    "db:migrate:kit": "bun drizzle-kit migrate",
    "db:inspect": "bun drizzle/inspect-migration.ts",
    "db:studio": "bun drizzle-kit studio",
    "db:fix": "bun drizzle/fix-migrations.ts",
    "seed": "bun drizzle/seed.ts",
    "test": "bun test",
    "test:e2e": "bun test test/**/*.e2e.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'drizzle/**/*.ts'"
  },
  "dependencies": {
    "@fastify/static": "^7.0.0",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.3.8",
    "@nestjs/swagger": "^7.3.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.30.10",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.21.2",
    "eslint": "^9.2.0",
    "prettier": "^3.2.5"
  }
}